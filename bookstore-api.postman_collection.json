  "item": [
    {
      "name": "Add Book (Success)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Saves the created book ID as environment variable\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"created_book_id\", jsonData.data._id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"The Hobbit\",\n  \"author\": \"J.R.R. Tolkien\",\n  \"genre\": \"Fantasy\",\n  \"price\": 10.99,\n  \"publishedDate\": \"1937-09-21\",\n  \"inStock\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/books",
          "host": [
            "{{base_url}}"
          ],
          "path": [
